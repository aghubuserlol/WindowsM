/*
 * PMGR power domains for the Apple T8132 "M4" SoC
 *
 * GENERATED by experimental/t8132-bringup/pmgr/generate-pmgr-dtsi.py
 * from the live Apple Device Tree of a Mac mini (2024, Mac16,10).
 * 392 ADT pmgr devices; emitting the main register block
 * (ps-regs reg_idx 0). Offsets and parent links are extracted, not
 * guessed. See pmgr/README.md.
 */

