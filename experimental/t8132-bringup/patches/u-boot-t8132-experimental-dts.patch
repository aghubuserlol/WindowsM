+// SPDX-License-Identifier: GPL-2.0+ OR MIT
+/*
+ * Apple T8132 "M4" SoC — EXPERIMENTAL minimal device tree
+ *
+ * STATUS: bring-up scaffolding, never successfully booted. Written for the
+ * WindowsM project as a starting point for T8132 support.
+ *
+ * Every MMIO address and topology fact in this file was extracted from the
+ * Apple Device Tree of a real Mac mini (2024, Mac16,10 / J773g) via macOS
+ * IORegistry (IODeviceTree plane), then translated through the arm-io
+ * "ranges" property to absolute addresses. Cross-check: the serial0 address
+ * derived here (0x3ad200000) independently matches EARLY_UART_BASE for
+ * TARGET == T8132 in upstream m1n1 src/soc.h.
+ *
+ * What is deliberately ABSENT (unknown, not guessable from the ADT):
+ *  - AIC interrupt numbers for every peripheral (requires tracing or Apple's
+ *    ADT interrupt parent decoding work) — interrupts properties are omitted;
+ *    U-Boot drivers poll and do not need them.
+ *  - The pmgr power/clock tree (1000+ lines on t8112) — this DT relies on
+ *    iBoot/m1n1 leaving the console and USB power domains enabled.
+ *  - atcphy programming for T8132 (PHY generation differs from t8112) —
+ *    USB nodes are present with real addresses but status = "disabled".
+ *
+ * Copyright The Asahi Linux Contributors (template structure, t8112.dtsi)
+ */
+
+/ {
+	compatible = "apple,t8132", "apple,arm-platform";
+	#address-cells = <2>;
+	#size-cells = <2>;
+	interrupt-parent = <&aic>;
+
+	cpus {
+		#address-cells = <2>;
+		#size-cells = <0>;
+
+		cpu-map {
+			cluster0 {
+				core0 { cpu = <&cpu_e0>; };
+				core1 { cpu = <&cpu_e1>; };
+				core2 { cpu = <&cpu_e2>; };
+				core3 { cpu = <&cpu_e3>; };
+				core4 { cpu = <&cpu_e4>; };
+				core5 { cpu = <&cpu_e5>; };
+			};
+
+			cluster1 {
+				core0 { cpu = <&cpu_p0>; };
+				core1 { cpu = <&cpu_p1>; };
+				core2 { cpu = <&cpu_p2>; };
+				core3 { cpu = <&cpu_p3>; };
+			};
+		};
+
+		/*
+		 * Topology from the live ADT: 6 E-cores (reg 0x0-0x5) + 4
+		 * P-cores (reg 0x100-0x103). Note the P-cluster base is 0x100,
+		 * NOT 0x10100 as on t8103/t8112. MIDR part numbers (upstream
+		 * m1n1 midr.h): Donan E-core 0x52, P-core 0x53. The ADT
+		 * declares the cores compatible "apple,sawtooth" (E) /
+		 * "apple,everest" (P); "apple,donan" is used here pending an
+		 * upstream binding decision.
+		 */
+		cpu_e0: cpu@0 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x0>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>; /* To be filled by loader */
+		};
+
+		cpu_e1: cpu@1 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x1>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_e2: cpu@2 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x2>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_e3: cpu@3 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x3>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_e4: cpu@4 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x4>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_e5: cpu@5 {
+			compatible = "apple,donan", "apple,sawtooth";
+			device_type = "cpu";
+			reg = <0x0 0x5>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_p0: cpu@100 {
+			compatible = "apple,donan", "apple,everest";
+			device_type = "cpu";
+			reg = <0x0 0x100>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_p1: cpu@101 {
+			compatible = "apple,donan", "apple,everest";
+			device_type = "cpu";
+			reg = <0x0 0x101>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_p2: cpu@102 {
+			compatible = "apple,donan", "apple,everest";
+			device_type = "cpu";
+			reg = <0x0 0x102>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+
+		cpu_p3: cpu@103 {
+			compatible = "apple,donan", "apple,everest";
+			device_type = "cpu";
+			reg = <0x0 0x103>;
+			enable-method = "spin-table";
+			cpu-release-addr = <0 0>;
+		};
+	};
+
+	clkref: clock-ref {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <24000000>;
+		clock-output-names = "clkref";
+	};
+
+	/*
+	 * Architectural timer. Interrupt routing on Apple SoCs is via FIQ;
+	 * interrupts are intentionally omitted (unknown AIC FIQ indices for
+	 * t8132 — U-Boot does not use them).
+	 */
+	timer {
+		compatible = "arm,armv8-timer";
+	};
+
+	soc {
+		compatible = "apple,arm-io", "simple-bus";
+		#address-cells = <2>;
+		#size-cells = <2>;
+		ranges;
+		nonposted-mmio;
+
+		/*
+		 * Third-generation AIC (ADT "aic,3"). m1n1 HEAD drives it
+		 * (src/aic.c, aic23_init(3,..)); no upstream Linux aic3 binding
+		 * yet. Single 0x1cc000 MMIO window (v3 folds the v2 core/event
+		 * split into one window; the iack lives at +0x40000 inside it).
+		 *
+		 * v3 register-layout offsets, all extracted from the live ADT
+		 * (see aic/extract-aic-params.py and aic/t8132-aic.md). m1n1
+		 * reads these from the real ADT at boot; recorded here so the
+		 * controller is fully described for an eventual Linux binding:
+		 *   cap0-offset        0x4
+		 *   maxnumirq-offset   0xc
+		 *   aic-iack-offset    0x40000
+		 *   extint-baseaddress 0x10000   (== m1n1 AIC3_IRQ_CFG)
+		 *   extintrcfg-stride  0x4a00
+		 *   #main-cpus         10         (6 E + 4 P)
+		 */
+		aic: interrupt-controller@381000000 {
+			compatible = "apple,t8132-aic", "apple,aic3";
+			#interrupt-cells = <3>;
+			interrupt-controller;
+			reg = <0x3 0x81000000 0x0 0x1cc000>;
+			reg-names = "core";
+			power-domains = <&ps_aic>; /* extracted ADT pmgr domain */
+		};
+
+		/*
+		 * ADT: "uart-1,samsung" at arm-io + 0x1ad200000, size 0x4000.
+		 * Absolute address confirmed by upstream m1n1 EARLY_UART_BASE.
+		 * Same Samsung-style UART as every Apple SoC since S5L.
+		 */
+		serial0: serial@3ad200000 {
+			compatible = "apple,s5l-uart";
+			reg = <0x3 0xad200000 0x0 0x4000>;
+			reg-io-width = <4>;
+			/* interrupts omitted: AIC index unknown, U-Boot polls */
+			clocks = <&clkref>, <&clkref>;
+			clock-names = "uart", "clk_uart_baud0";
+			power-domains = <&ps_uart0>; /* extracted ADT pmgr domain */
+			status = "disabled";
+		};
+
+		/*
+		 * ADT: "wdt,t8132", "wdt,s5l8960x" at arm-io + 0x1882b0000 —
+		 * the same S5L-lineage watchdog driven by existing drivers.
+		 */
+		wdt: watchdog@3882b0000 {
+			compatible = "apple,t8132-wdt", "apple,wdt";
+			reg = <0x3 0x882b0000 0x0 0x4000>;
+			clocks = <&clkref>;
+		};
+
+		/*
+		 * Power manager. Base 0x380700000 is the ADT "pmgr-reg-base"
+		 * decoded from this machine; window size mirrors the t8112
+		 * convention (0x14000). The ADT perf-domains seen here are:
+		 * SOC, ECPU, DCS, PCPU, ANE, DISP, PMP-SOC, PMP-FAB[0-3],
+		 * PMP-DCS. The per-device power-domain child nodes (ps_*,
+		 * ~80 entries with per-device register offsets) are the
+		 * remaining mechanical extraction from the ADT "devices" blob —
+		 * a syscon with no children still lets drivers map the block.
+		 */
+		pmgr: power-management@380700000 {
+			compatible = "apple,t8132-pmgr", "apple,pmgr",
+				     "syscon", "simple-mfd";
+			#address-cells = <1>;
+			#size-cells = <1>;
+			reg = <0x3 0x80700000 0x0 0x14000>;
+			/* ps_* power-domain children added by t8132-pmgr.dtsi */
+		};
+
+		/*
+		 * ADT: "dart,t8110" — the USB DARTs are a generation that
+		 * existing apple-dart drivers already support. Disabled only
+		 * because the USB path as a whole (atcphy) is not usable yet.
+		 */
+		dart_usb0: iommu@402f00000 {
+			compatible = "apple,t8110-dart";
+			reg = <0x4 0x02f00000 0x0 0xc000>;
+			#iommu-cells = <1>;
+			status = "disabled";
+		};
+
+		dart_usb1: iommu@40af00000 {
+			compatible = "apple,t8110-dart";
+			reg = <0x4 0x0af00000 0x0 0xc000>;
+			#iommu-cells = <1>;
+			status = "disabled";
+		};
+
+		/*
+		 * ADT: "usb-drd,t8132" — dwc3 core block (first reg region).
+		 * Needs atcphy bring-up before it can be enabled.
+		 */
+		usb_drd0: usb@402280000 {
+			compatible = "apple,t8132-dwc3", "apple,dwc3", "snps,dwc3";
+			reg = <0x4 0x02280000 0x0 0x11800>;
+			dr_mode = "host";
+			iommus = <&dart_usb0 0>;
+			status = "disabled";
+		};
+
+		usb_drd1: usb@40a280000 {
+			compatible = "apple,t8132-dwc3", "apple,dwc3", "snps,dwc3";
+			reg = <0x4 0x0a280000 0x0 0x11800>;
+			dr_mode = "host";
+			iommus = <&dart_usb1 0>;
+			status = "disabled";
+		};
+
+		/*
+		 * ADT: "atc-phy,t8132" at 0x402a90000. The T8132 Type-C PHY
+		 * generation is NOT compatible with the t8112 atcphy driver;
+		 * listed for completeness, requires real bring-up work.
+		 */
+		atcphy0: phy@402a90000 {
+			compatible = "apple,t8132-atcphy";
+			reg = <0x4 0x02a90000 0x0 0x4000>;
+			#phy-cells = <1>;
+			status = "disabled";
+		};
+	};
+};
+
+/* 123 power domains extracted from the live ADT (see pmgr/generate-pmgr-dtsi.py). */
+#include "t8132-pmgr.dtsi"
